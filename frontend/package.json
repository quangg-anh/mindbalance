{
  "name": "@game/frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "vite --port 4173",
    "build": "npm run build -w @game/shared -w @game/game-content -w @game/game-core && tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "validate:story": "vitest run packages/game-content/src/validator.test.ts",
    "simulate": "vitest run packages/game-core/src/simulator.test.ts",
    "e2e": "playwright test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@game/game-content": "*",
    "@game/game-core": "*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.40.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vite-plugin-pwa": "^1.0.1",
    "vitest": "^3.2.4"
  }
}
