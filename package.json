{
  "name": "bon-nam-thanh-xuan",
  "private": true,
  "version": "1.0.0",
  "workspaces": ["frontend", "backend", "packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "concurrently -n frontend,backend -c cyan,green \"npm run dev -w @game/frontend\" \"npm run dev -w @game/backend\"",
    "dev:frontend": "npm run dev -w @game/frontend",
    "dev:backend": "npm run dev -w @game/backend",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:story": "vitest run packages/game-content/src/validator.test.ts",
    "simulate": "vitest run packages/game-core/src/simulator.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
